<?xml version="1.0" encoding="UTF-8"?>
<schema xmlns="http://example.com/binarymessage" namespace="acme.telemetry.invalid">
  <messageType name="InvalidLogicalOperator" comment="Uses unsupported logicalOperator value">
    <field name="version" type="uint8" comment="Version field"/>
    <if field="version" operator="gte" value="2"
        logicalOperator="xor" field2="version" operator2="lte" value2="10">
      <field name="mode" type="uint8" comment="Mode field"/>
    </if>
  </messageType>
</schema>
