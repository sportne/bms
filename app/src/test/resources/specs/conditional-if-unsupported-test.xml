<?xml version="1.0" encoding="UTF-8"?>
<schema xmlns="http://example.com/binarymessage" namespace="acme.telemetry.conditional.backend">
  <messageType name="ConditionalUnsupportedIf" comment="Uses unsupported compound if expression syntax">
    <field name="version" type="uint8" comment="Version byte"/>
    <if test="version > 1 &amp;&amp; version &lt; 10">
      <field name="modeValue" type="uint8" comment="Mode value"/>
    </if>
  </messageType>
</schema>
