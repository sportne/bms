<?xml version="1.0" encoding="UTF-8"?>
<schema xmlns="http://example.com/binarymessage" namespace="acme.telemetry.conditional.relational">
  <messageType name="ConditionalRelationalFrame" comment="Valid relational if@test operator fixture">
    <field name="version" type="uint8" comment="Version byte"/>
    <if field="version" operator="lt" value="10">
      <field name="ltMode" type="uint8" comment="Field emitted for less-than"/>
    </if>
    <if field="version" operator="lte" value="10">
      <field name="lteMode" type="uint8" comment="Field emitted for less-than-or-equal"/>
    </if>
    <if field="version" operator="gt" value="1">
      <field name="gtMode" type="uint8" comment="Field emitted for greater-than"/>
    </if>
    <if field="version" operator="gte" value="1">
      <field name="gteMode" type="uint8" comment="Field emitted for greater-than-or-equal"/>
    </if>
    <if test="version &gt;= 2 and version &lt;= 10">
      <field name="betweenMode" type="uint8" comment="Field emitted for text-and condition"/>
    </if>
    <if test="(version == 2 or version == 3) and version &lt; 5">
      <field name="compoundMode" type="uint8" comment="Field emitted for parenthesized text condition"/>
    </if>
  </messageType>
</schema>
