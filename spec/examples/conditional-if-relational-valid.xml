<?xml version="1.0" encoding="UTF-8"?>
<schema xmlns="http://example.com/binarymessage" namespace="acme.telemetry.conditional.relational">
  <messageType name="ConditionalRelationalFrame" comment="Example relational if@test operators">
    <field name="version" type="uint8" comment="Version byte"/>
    <if field="version" operator="lt" value="10">
      <field name="ltMode" type="uint8" comment="Field for less-than"/>
    </if>
    <if field="version" operator="lte" value="10">
      <field name="lteMode" type="uint8" comment="Field for less-than-or-equal"/>
    </if>
    <if field="version" operator="gt" value="1">
      <field name="gtMode" type="uint8" comment="Field for greater-than"/>
    </if>
    <if field="version" operator="gte" value="1">
      <field name="gteMode" type="uint8" comment="Field for greater-than-or-equal"/>
    </if>
  </messageType>
</schema>
